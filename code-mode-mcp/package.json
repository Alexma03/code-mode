{
  "name": "@utcp/code-mode-mcp",
  "version": "1.2.0",
  "description": "Model Context Protocol (MCP) server for UTCP Code Mode - Execute TypeScript code with direct tool access",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-bridge": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "utcp",
    "mcp",
    "code-mode",
    "typescript",
    "model-context-protocol",
    "universal-tool-calling-protocol",
    "bridge",
    "tools",
    "ai",
    "code-execution"
  ],
  "author": "UTCP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alexma03/code-mode.git",
    "directory": "code-mode-mcp"
  },
  "homepage": "https://github.com/Alexma03/code-mode#readme",
  "bugs": {
    "url": "https://github.com/Alexma03/code-mode/issues"
  },
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "5.0.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.20.2",
    "@utcp/cli": "file:../typescript-utcp/packages/cli",
    "@utcp/code-mode": "file:../typescript-library",
    "@utcp/dotenv-loader": "file:../typescript-utcp/packages/dotenv-loader",
    "@utcp/file": "file:../typescript-utcp/packages/file",
    "@utcp/http": "file:../typescript-utcp/packages/http",
    "@utcp/mcp": "file:../typescript-utcp/packages/mcp",
    "@utcp/sdk": "file:../typescript-utcp/packages/core",
    "@utcp/text": "file:../typescript-utcp/packages/text",
    "dotenv": "16.0.0",
    "zod": "3.25.76"
  }
}
